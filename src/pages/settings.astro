---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Settings">
  <section class="page-header">
    <p class="eyebrow">App Preferences</p>
    <h1>Settings</h1>
    <p>Placeholders for features coming in later phases.</p>
  </section>

  <section class="settings-grid">
    <article class="feature-card">
      <h3>Currency</h3>
      <p>Default: Philippine Peso (PHP)</p>
    </article>
    <article class="feature-card">
      <h3>Budget Month</h3>
      <p>Choose the month you want to track.</p>
    </article>
    <article class="feature-card">
      <h3>Categories</h3>
      <p>Organize income, savings, and expenses.</p>
    </article>
    <article class="feature-card">
      <h3>Theme</h3>
      <p>Switch between visual styles and density.</p>
    </article>
    <article class="feature-card">
      <h3>Export Data</h3>
      <p>Export budget summaries when ready.</p>
    </article>
  </section>
</BaseLayout>
